# ─── Server ───────────────────────────────────────────────
PORT=3000
# development | production. In production, synchronize is off and migrations run.
NODE_ENV=development
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8081
ADMIN_DASHBOARD_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────
# Postgres (Neon or self-hosted). Append ?sslmode=require for Neon.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DB_TYPE=postgres
# Set to 'sqlite' for zero-setup local dev (uses backend/data/expense_tracker.db).
# Discrete Postgres settings (used only if DATABASE_URL is unset):
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=expense_tracker
# Schema-sync control. Leave unset to default to true in development only.
# In production keep it false and rely on migrations (npm run migration:run).
# DB_SYNCHRONIZE=false

# ─── Authentication ───────────────────────────────────────
# REQUIRED. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
# Access-token lifetime. Refresh tokens (7d) handle longer sessions.
JWT_EXPIRES_IN=1h
# Optional: 32-byte key enabling AES-256-GCM encryption of phoneNumber at rest.
ENCRYPTION_KEY=

# ─── LLM ──────────────────────────────────────────────────
# openai | self-hosted
LLM_PROVIDER=openai
# Required when LLM_PROVIDER=openai (categorization, Whisper voice, chat, receipts).
OPENAI_API_KEY=
# Only when LLM_PROVIDER=self-hosted:
# OpenAI-compatible base URL; the code appends /chat/completions (e.g. Ollama: http://localhost:11434/v1)
# SELF_HOSTED_LLM_URL=http://localhost:11434/v1
# SELF_HOSTED_LLM_API_KEY=
# SELF_HOSTED_LLM_MODEL=llama3

# ─── Currency ─────────────────────────────────────────────
# Optional — the free keyless endpoint is used by default; key enables fixer.io fallback.
EXCHANGE_RATE_API_KEY=

# ─── Receipt OCR (optional) ───────────────────────────────
GOOGLE_VISION_API_KEY=

# ─── Stripe (optional, for premium subscriptions) ─────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=

# ─── WhatsApp Business API (optional) ─────────────────────
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Meta App Secret — required to verify webhook signatures (X-Hub-Signature-256).
WHATSAPP_APP_SECRET=

# ─── Telegram Bot (optional) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
# Set both of these to run in webhook (production) mode instead of polling.
TELEGRAM_WEBHOOK_URL=
# Strong random string Telegram echoes back so forged webhook POSTs are rejected.
TELEGRAM_WEBHOOK_SECRET=

# ─── Google Sign-In ───────────────────────────────────────
# Web OAuth client ID; the backend verifies Google id_tokens against it.
GOOGLE_CLIENT_ID=
# Native OAuth client IDs — the backend also accepts id_tokens issued to these
# (iOS/Android builds issue tokens whose audience is the native client ID).
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# ─── Group invites (optional) ─────────────────────────────
# If set, invite links use this web base (e.g. a landing page that opens the app).
# Otherwise a deep link (expensetracker://invite/<token>) is returned.
APP_INVITE_BASE_URL=
