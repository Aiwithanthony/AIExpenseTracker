# Backend base URL the app calls.
# - iOS simulator / web: http://localhost:3000 works.
# - Physical device: use your computer's LAN IP, e.g. http://192.168.1.20:3000
#   (the device and computer must be on the same network).
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Google Sign-In (optional) ────────────────────────────
# Web OAuth client ID (used by Expo Go and as the backend audience).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Native client IDs — required for Google Sign-In in standalone / dev builds.
# Create iOS and Android OAuth clients in Google Cloud Console, then fill these in.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
